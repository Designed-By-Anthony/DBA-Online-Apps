# ── Clerk Authentication (Satellite Domain) ──────────────────
# Same Clerk app as designedbyanthony.com — use the SAME keys.
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Satellite domain config — tells Clerk this is NOT the primary
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=designedbyanthony.online

# Auth flows redirect to the primary domain (.com)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://designedbyanthony.com/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://designedbyanthony.com/sign-up

# ── Cloudflare ────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
