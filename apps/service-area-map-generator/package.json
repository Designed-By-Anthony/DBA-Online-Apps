{
  "name": "@dba/service-area-map-generator",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "next dev --port 3204",
    "build": "node ../../scripts/require-clerk-build-env.mjs && next build",
    "pages:build": "node ../../scripts/require-clerk-build-env.mjs && next build",
    "pages:deploy": "bunx wrangler deploy",
    "lint": "biome check .",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@dba/ui": "workspace:*",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@dba/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
