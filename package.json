{
  "name": "dba-online-apps-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "check-types": "turbo run check-types",
    "pages:build": "turbo run pages:build",
    "pages:deploy": "turbo run pages:deploy",
    "deploy:apps": "turbo run pages:deploy",
    "deploy:api": "bun run --cwd packages/api deploy",
    "verify:apps": "turbo run build check-types lint --filter=@dba/*",
    "deploy": "bun run build && bun run check-types && bun run deploy:api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@dba/config-biome": "workspace:*",
    "@playwright/test": "^1.52.0",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.22.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
